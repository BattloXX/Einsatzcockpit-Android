<!-- Berechtigungen für AndroidManifest.xml
     Hinzuzufügen in android/app/src/main/AndroidManifest.xml
     nach dem <uses-sdk>-Tag und vor <application> -->

<uses-permission android:name="android.permission.INTERNET" />
<uses-permission android:name="android.permission.POST_NOTIFICATIONS" />  <!-- Android 13+ -->

<!-- GPS / Standort -->
<uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
<uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
<uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" /> <!-- Android 10+ -->

<!-- Foreground-Service für Background-GPS -->
<uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
<uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" /> <!-- Android 14+ -->

<!-- Kamera für QR-Scanner und Foto-Upload (Einsatz-/Aufgaben-/Stellen-Medien) -->
<uses-permission android:name="android.permission.CAMERA" />
<uses-feature android:name="android.hardware.camera" android:required="false" />

<!-- Wake Lock (Bildschirm aktiv halten) -->
<uses-permission android:name="android.permission.WAKE_LOCK" />

<!-- Vibration für Benachrichtigungen -->
<uses-permission android:name="android.permission.VIBRATE" />

<!-- SMS-Gateway (vom Plugin-Manifest eingebracht, hier zur Dokumentation) -->
<uses-permission android:name="android.permission.SEND_SMS" />
<uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
<uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" /> <!-- Android 14+ (kein 6h-Limit wie dataSync unter Android 15) -->
<uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
